<h1>SEO Checker</h1>

<p class="subtitle">Enter a URL to analyze its basic SEO signals.</p>

<% if @error.present? %>
  <div class="alert" role="alert">
    <strong>Error:</strong> <%= @error %>
  </div>
<% end %>

<%# Simple, beginner-friendly form %>
<%= form_with url: seo_reports_path, method: :post, local: true, class: "card" do |form| %>
  <div class="field">
    <%= form.label :url, "URL" %>
    <%= form.text_field :url,
      value: @url,
      placeholder: "https://example.com",
      required: true,
      class: "input" %>
  </div>

  <div>
    <%= form.submit "Check SEO", class: "button" %>
  </div>
<% end %>
