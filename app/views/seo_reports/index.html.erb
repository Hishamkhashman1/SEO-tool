<section class="hero">
  <div>
    <p class="eyebrow">SEO Scanner</p>
    <h1>SEO Signal Console</h1>
    <p class="subtitle">Drop a URL and get a cyber-punk grade on its on-page SEO signals.</p>
  </div>
</section>

<% if @error.present? %>
  <div class="alert" role="alert">
    <strong>Error:</strong> <%= @error %>
  </div>
<% end %>

<%# Simple, beginner-friendly form %>
<%= form_with url: seo_reports_path, method: :post, local: true, class: "card" do |form| %>
  <div class="field">
    <%= form.label :url, "Target URL" %>
    <%= form.text_field :url,
      value: @url,
      placeholder: "https://example.com",
      required: true,
      class: "input" %>
  </div>

  <div>
    <%= form.submit "Run Scan", class: "button" %>
  </div>
<% end %>
