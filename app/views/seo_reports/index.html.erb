<h1>SEO Checker</h1>

<p>Enter a URL to analyze its basic SEO signals.</p>

<% if @error.present? %>
  <div role="alert">
    <strong>Error:</strong> <%= @error %>
  </div>
<% end %>

<%= form_with url: seo_reports_path, method: :post, local: true do |form| %>
  <div>
    <%= form.label :url, "URL" %><br>
    <%= form.text_field :url, value: @url, placeholder: "https://example.com", required: true %>
  </div>

  <div>
    <%= form.submit "Check SEO" %>
  </div>
<% end %>
